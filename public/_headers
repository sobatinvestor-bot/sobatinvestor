/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()

# Entry HTML: jangan pernah sajikan versi lama dari cache.
# Selalu revalidasi ke server supaya tidak menunjuk bundle yang sudah dihapus
# setelah deploy (penyebab layar blank).
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# Aset ber-hash (nama unik tiap build) aman di-cache lama.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
