/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()

# index.html JANGAN di-cache permanen — selalu revalidasi supaya selalu menunjuk
# file JS/CSS terbaru. Ini mencegah layar blank setiap kali ada deploy baru.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache

# Aset ber-hash (nama berubah tiap build) boleh di-cache selamanya.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
